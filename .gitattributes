# Force LF everywhere — repo and working tree, both on Linux and Windows 11 machine.
* text=auto eol=lf

# Explicit code files (belt and braces)
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.ts      text eol=lf
*.vue     text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.svg     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.sql     text eol=lf

# Windows-only scripts (force CRLF)
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary assets
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.woff    binary
*.woff2   binary
*.ttf     binary

# Generated files
*.min.js  binary
*.map     binary
